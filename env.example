# Supabase — crea un progetto su supabase.com, poi vai su Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tuoprogetto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la-tua-anon-key
SUPABASE_SERVICE_ROLE_KEY=la-tua-service-role-key

# kie.ai — la tua API key esistente (stessa usata in Promo Music Italia)
KIE_AI_API_KEY=la-tua-kie-ai-key

# Anthropic — per la generazione di lyrics/concept
ANTHROPIC_API_KEY=la-tua-anthropic-key
